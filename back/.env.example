# Configuration de la plateforme de veille — copier en .env (toutes les clés sont
# OPTIONNELLES : sans .env, le pipeline tourne en mode dégradé sans clé).

# --- Mode IA (optionnel) ---------------------------------------------------
# Présente → résumés/catégorisation par Claude ; absente → mode dégradé.
# ANTHROPIC_API_KEY=sk-ant-...
# Haiku 4.5 = le moins cher, suffisant ici (~0,10 $/run de 40 articles).
# Alternatives qualité : claude-sonnet-5 (~0,35 $/run) · claude-opus-4-8 (~1,8 $/run).
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# --- Ingestion / filtre qualité --------------------------------------------
MAX_ITEMS_PER_SOURCE=20      # articles retenus par source et par run (plafond par source)
MAX_NEW_PER_RUN=40           # plafond GLOBAL de nouveaux articles/run (tous résumés le run même)
MIN_CONTENT_CHARS=120        # sous ce seuil, un article est jugé sans valeur (rejeté)
HN_RECENCY_DAYS=30           # Hacker News : fenêtre récente (évite les vieux posts)

# --- Extraction plein texte (bonus qualité, optionnel) ---------------------
# Va chercher le corps réel des pages (réhabilite Hacker News, enrichit TechCrunch).
# Nécessite `uv add trafilatura`.
ENRICH_FULLTEXT=0            # 1 pour activer
FULLTEXT_MIN_CHARS=600       # sous ce seuil de contenu, on tente l'extraction
FULLTEXT_TIMEOUT=10          # secondes

# --- Résumé : vulgarisation / traduction locale (sans clé) -----------------
TRANSLATE_BACKEND=auto       # auto | ollama | argos | off
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
REQUIRE_LLM_SUMMARY=0         # 1 = pas de repli anglais : si LLM injoignable, article laissé en attente (retenté)

# --- Enrichissement (résumé/catégo) : débit -------------------------------
MAX_ENRICH_PER_RUN=40        # articles résumés par run (idempotent : relancer traite le reste)
ENRICH_WORKERS=3             # appels LLM concurrents (bornés réseau/GPU)

# --- Recherche sémantique (bonus, optionnel) -------------------------------
# Nécessite `uv add sentence-transformers` (modèle ~80 Mo).
SEMANTIC_SEARCH=0            # 1 pour activer, puis `python main.py embed`

# --- Découverte autonome de sources (bonus, optionnel) ---------------------
# `python main.py discover` trouve et valide de nouvelles sources ; le pipeline les
# ingère ensuite et la boucle d'auto-ajustement élague les mauvaises. Socle YAML gardé.
SOURCE_DISCOVERY=0          # 1 pour activer la commande discover
DISCOVERY_WEB=0             # 1 = recherche web via ddgs (`uv pip install ddgs`)
DISCOVERY_LLM=0             # 1 = le LLM local (Ollama) propose des médias à valider
DISCOVERY_MAX_PER_DOMAIN=3  # nb max de sources ajoutées par domaine et par run
DISCOVERY_MIN_RECENT=3      # entrées récentes minimales pour valider un flux
DISCOVERY_FRESH_DAYS=30     # fenêtre de fraîcheur d'un flux
SOURCE_QUALITY_MIN=0.15     # sous ce seuil, une source découverte est élaguée…
SOURCE_MIN_RUNS=3           # …après ce nombre de runs évalués

# --- Comptes (sessions Flask) ----------------------------------------------
# Clé de signature des cookies de session. EN PROD : mettre une valeur secrète aléatoire.
SECRET_KEY=dev-le-guetteur-change-me

# --- Stockage / serveur ----------------------------------------------------
VEILLE_DB=data/veille.db     # chemin de la base SQLite
# FLASK_DEBUG=1              # dev uniquement
